# Claude Enterprise SDK Environment Configuration
# Copy this file to .env and fill in your values

# Context store location (default: ./context_store)
# CLAUDE_SDK_STORE_PATH=./context_store

# Default working directory (default: current directory)
# CLAUDE_SDK_WORKING_DIR=.

# Enable audit logging (default: true)
# CLAUDE_SDK_AUDIT_ENABLED=true

# Log level (default: INFO)
# CLAUDE_SDK_LOG_LEVEL=INFO
